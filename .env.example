# ── Guardrail Sentinel Playwright Config ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.

# Folder name of the unpacked extension inside the project root
EXTENSION_FOLDER=sentinel-extension-chrome-v0.5.52

# Chrome user-data dir (relative to project root, created automatically)
USER_DATA_DIR=.playwright-user-data

# Full path to Google Chrome on this machine
# Windows default:
CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS default:
# CHROME_EXE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Guardrail Sentinel login credentials
SENTINEL_EMAIL=your-email@example.com
SENTINEL_PASSWORD=your-password
